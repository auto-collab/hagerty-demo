# =============================================================================
# CONTAINERFILE - Demonstrating Core Container Concepts
# =============================================================================
# Concepts demonstrated:
#   - Layer ordering (least to most frequently changed)
#   - RUN chaining to avoid layer bloat
#   - WORKDIR
#   - USER and GROUP (non-root security)
#   - ENTRYPOINT vs CMD
# =============================================================================

# -------------------------------------
# LAYER 1: Base image
# This layer is pulled from a registry and cached locally.
# It will never change unless we update the base tag.
# Ordering it first means it will almost always be a cache hit.
# -------------------------------------
FROM alpine:3.18

# -------------------------------------
# LAYER 2: Install dependencies
# Alpine uses apk instead of apt-get.
# We chain the install AND cleanup into ONE RUN command so that
# the apk cache files never make it into any layer.
# If we used two separate RUN commands, the cache files would be
# permanently baked into the first layer even after cleanup.
# -------------------------------------
RUN apk add --no-cache netcat-openbsd wget

# -------------------------------------
# LAYER 3: Create a non-root group and user
# Running as root inside a container is a security risk.
# Root inside the container can become root on the host
# if there is a container escape vulnerability.
# We create a dedicated group and user for our app instead.
# -------------------------------------
RUN groupadd -r appgroup && useradd -r -g appgroup appuser

# -------------------------------------
# LAYER 4: Set the working directory
# WORKDIR creates /app if it doesn't exist and sets it
# as the default directory for all subsequent instructions
# and for the running container process.
# This is preferred over: RUN cd /app && ...
# -------------------------------------
WORKDIR /app

# -------------------------------------
# LAYER 5: Copy application files
# We copy files AFTER installing dependencies intentionally.
# Dependencies change rarely. Our app code changes frequently.
# By putting COPY after RUN, a code change only invalidates
# this layer and below - the dependency layer stays cached.
#
# --chown assigns ownership to our non-root user so the
# process can actually read and execute the files.
# -------------------------------------
COPY --chown=appuser:appgroup app/server.sh .

# Make the script executable
RUN chmod +x server.sh

# -------------------------------------
# Switch to non-root user
# Everything from here runs as appuser, including the
# final container process. This is the security boundary.
# -------------------------------------
USER appuser

# -------------------------------------
# ENTRYPOINT vs CMD
#
# ENTRYPOINT: the fixed executable - this container IS a server.
# It cannot be replaced at runtime, only appended to.
# We use exec form ["cmd"] not shell form "cmd" so our process
# is PID 1 directly and receives signals like SIGTERM correctly.
#
# CMD: default arguments passed to the entrypoint.
# These CAN be overridden at runtime:
#   docker run myimage --port 9090
# -------------------------------------
ENTRYPOINT ["sh", "server.sh"]
CMD []
